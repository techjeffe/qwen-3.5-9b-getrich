  "continuous_entry": {
    "_comment": "Replaces the binary entry gate with a sigmoid curve. size_pct = min + (max - min) / (1 + exp(-steepness * (|score| - midpoint))). At |score|=midpoint the position is 50% of full size. Scores below skip_floor get 0% (skip entirely).",
    "enabled": true,
    "sigmoid_midpoint": 0.42,
    "sigmoid_steepness": 6.0,
    "min_size_pct": 10.0,
    "max_size_pct": 100.0,
    "_comment_skip_floor": "Absolute directional_score below this threshold skips the signal entirely (no entry, even at min_size). Prevents micro-signals from creating noise.",
    "skip_floor": 0.10,
    "_comment_shrink_existing": "When an existing position's score stays above keep_floor, shrink proportionally instead of closing. Below keep_floor, close entirely.",
    "keep_floor": 0.10
  },
  "accumulate_on_confirmation": {
    "_comment": "When enabled, re-confirmed signals (same ticker/leverage/direction) add additional shares up to max_multiplier × base_amount. The entry price is blended (weighted average).",
    "enabled": true,
    "max_multiplier": 5.0
  },
  "reentry_cooldown_minutes": 120,
  "min_same_day_exit_edge_pct": 0.5,
  "stop_loss_pct": 2.0,
  "take_profit_pct": 3.0,
  "leverage": {
    "_comment": "ATR-based volatility caps. When 14-day ATR % exceeds high_vol_atr_pct the position is capped at 1x regardless of profile. Exceeding medium_vol_atr_pct caps at 2x. Conservative profile (inverse ETF) is unaffected.",
    "high_vol_atr_pct": 3.0,
    "medium_vol_atr_pct": 1.5
  },
  "trailing_stop": {
    "_comment": "When a HOLD signal fires on an open position, a trailing stop is set instead of forcing a market close. Stop = best_price_seen × (1 ± stop_loss_pct × tighten_factor). Updated every run while in trailing mode.",
